# Groq — used for Whisper STT (free tier, ~1s latency)
# Get a key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# OpenRouter — used for the post-edit LLM (Claude Haiku by default).
# Optional: if absent, post-edit falls back to Groq Llama 3.3 (free tier).
# Get a key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your_key_here
